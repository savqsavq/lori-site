---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact">
  <div class="page-header">
    <h1>Get in Touch</h1>
    <p>For classes, commissions, parties, and bookings.</p>
  </div>

  <div class="content">

    <div class="contact-grid">

      <div class="contact-info">
        <h2>Contact Lori</h2>

        <div class="info-item">
          <span class="label">Email</span>
          <a href="mailto:LoriRene@gmail.com">LoriRene@gmail.com</a>
        </div>

        <div class="info-item">
          <span class="label">Phone</span>
          <a href="tel:6017912388">601-791-2388</a>
        </div>

        <div class="info-item">
          <span class="label">Summer Camp Registration</span>
          <a href="https://fatcatbooking.as.me/schedule/ecd40bb4/?categories[]=Lori%27s%20Art%20Camp" target="_blank">Register at Fat Cat Art Cafe</a>
        </div>

        <h2 class="socials-heading">Follow Lori</h2>

        <div class="info-item">
          <span class="label">Instagram</span>
          <a href="https://instagram.com/artbylorirene" target="_blank">@artbylorirene</a>
        </div>

        <div class="info-item">
          <span class="label">Instagram</span>
          <a href="https://instagram.com/7Lori__Rene7" target="_blank">@7Lori__Rene7</a>
        </div>

        <div class="info-item">
          <span class="label">Facebook</span>
          <a href="https://facebook.com/Lorirene" target="_blank">Lorirene</a>
        </div>

        <div class="info-item">
          <span class="label">Facebook</span>
          <a href="https://facebook.com/ArtWorksStudios" target="_blank">ArtWorksStudios</a>
        </div>

        <div class="info-item">
          <span class="label">YouTube</span>
          <a href="https://youtube.com/@LoriRene2520" target="_blank">LoriRene2520</a>
        </div>
      </div>
    </div>

  </div>
</Layout>

<style>
  .page-header {
    text-align: center;
    padding: 3rem 2rem 1rem;
    background: var(--dark);
    color: white;
  }

  .page-header h1 {
    font-family: var(--font-display);
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .page-header p {
    opacity: 0.8;
    font-size: 1rem;
  }

  .content {
    max-width: 1000px;
    margin: 0 auto;
    padding: 3rem 2rem 5rem;
  }

  .contact-grid {
    display: flex;
    gap: 4rem;
    align-items: flex-start;
    flex-wrap: wrap;
  }

  .contact-info {
    flex: 1;
    min-width: 280px;
  }

  h2 {
    font-family: var(--font-display);
    font-size: 1.6rem;
    color: var(--pink);
    margin-bottom: 1.5rem;
  }

  .socials-heading {
    margin-top: 2.5rem;
  }

  .info-item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    margin-bottom: 1.25rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid #f0f0f0;
  }

  .info-item:last-child {
    border-bottom: none;
  }

  .label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #999;
    font-weight: 500;
  }

  .info-item a {
    color: var(--dark);
    text-decoration: none;
    font-size: 1rem;
    font-weight: 500;
    transition: color 0.2s;
  }

  .info-item a:hover {
    color: var(--pink);
  }
  
  @media (max-width: 768px) {
    .contact-grid { flex-direction: column-reverse; }
    .contact-image { max-width: 100%; flex: 1; }
  }
</style>