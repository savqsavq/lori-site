---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Parties & Events">
  <div class="page-header">
    <h1>Parties & Events</h1>
    <p>Make your celebration unforgettable with art, creativity, and fun.</p>
  </div>

  <div class="content">

    <section class="birthday">
      <div class="text">
        <h2>Birthday Parties</h2>
        <p>Lori brings the art studio to your party. Kids get to create their own masterpiece in a fun, guided setting — no experience needed, just imagination. Perfect for ages 5 and up.</p>
        <p>Contact Lori to discuss themes, group size, location, and pricing.</p>
      </div>
    </section>

    <section class="facepainting">
      <div class="text-and-image">
        <div class="text">
          <h2>Face Painting</h2>
          <p>Add some magic to your event with professional face painting by Lori Rene. Great for birthday parties, school events, festivals, and more.</p>
          <p>Available for private bookings — reach out to check availability.</p>
        </div>
        <div class="face-img">
          <img src="/images/parties-events/facepainting.jpg " alt="Face painting by Lori Rene" />
        </div>
      </div>
    </section>
    <section class="cta">
      <h2>Book Lori for Your Event</h2>
      <p>Whether it's a birthday party, face painting, or a custom event, get in touch to check availability and pricing.</p>
      <a href="/contact" class="btn-primary">Contact Lori</a>
    </section>
  </div>
</Layout>

<style>
  .page-header {
    text-align: center;
    padding: 3rem 2rem 1rem;
    background: var(--pink);
    color: white;
  }

  .page-header h1 {
    font-family: var(--font-display);
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .page-header p {
    font-size: 1rem;
    opacity: 0.9;
  }

  .content {
    max-width: 900px;
    margin: 0 auto;
    padding: 3rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  h2 {
    font-family: var(--font-display);
    font-size: 1.8rem;
    color: var(--pink);
    margin-bottom: 1rem;
  }

  p {
    color: #444;
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .text-and-image {
    display: flex;
    gap: 3rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .text-and-image .text {
    flex: 1;
    min-width: 260px;
  }

  .face-img {
    flex: 1;
    min-width: 260px;
    border-radius: 12px;
    overflow: hidden;
    border: 4px solid var(--pink);
  }

  .face-img img {
    width: 100%;
    display: block;
    object-fit: cover;
  }

  .btn-primary {
    display: inline-block;
    background: var(--pink);
    color: white;
    padding: 0.75rem 1.5rem;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    transition: opacity 0.2s;
  }

  .btn-primary:hover { opacity: 0.85; }

  .btn-secondary {
    display: inline-block;
    background: transparent;
    color: var(--pink);
    padding: 0.75rem 1.5rem;
    border-radius: 6px;
    border: 2px solid var(--pink);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    transition: all 0.2s;
  }

  .btn-secondary:hover {
    background: var(--pink);
    color: white;
  }
  .cta {
    text-align: center;
    background: #f9f9f9;
    border-radius: 12px;
    padding: 3rem 2rem;
  }
</style>
