<Layout title="Gallery">
  <div class="gallery-header">
    <h1>Gallery</h1>
    <p>Original artwork, paintings, sculptures, and classroom work by Lori Renè.</p>
  </div>

  <div class="gallery-grid">
    {images.map((img) => (
      <div class="gallery-item">
        <img
          src={`/images/${img}`}
          alt="Artwork by Lori Renè"
          loading="lazy"
        />
      </div>
    ))}
  </div>
</Layout>

<style>
  .gallery-header {
    text-align: center;
    padding: 3rem 2rem 2rem;
  }

  .gallery-header h1 {
    font-family: var(--font-display);
    font-size: 2.5rem;
    color: var(--pink);
    margin-bottom: 0.5rem;
  }

  .gallery-header p {
    color: #555;
    font-size: 1rem;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 12px;
    padding: 1rem 2rem 4rem;
    max-width: 1400px;
    margin: 0 auto;
  }

  .gallery-item {
    overflow: hidden;
    border-radius: 8px;
    background: #f0f0f0;
    aspect-ratio: 1;
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .gallery-item:hover img {
    transform: scale(1.04);
  }
</style>