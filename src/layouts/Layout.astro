---
interface Props {
  title?: string;
}
const { title = "Lori Rene" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Lori Rene</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <nav>
      <a href="/" class="logo">Lori Rene</a>
      <ul>
        <li><a href="/gallery">Gallery</a></li>
        <li><a href="/classes">Classes & Lessons</a></li>
        <li><a href="/parties">Parties & Events</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </nav>

    <slot />

    <footer>
      <p>© 2026 Lori Rene · <a href="mailto:LoriRene@gmail.com">LoriRene@gmail.com</a> · 601-791-2388</p>
      <div class="socials">
        <a href="https://instagram.com/artbylorirene" target="_blank">Instagram</a>
        <a href="https://facebook.com/Lorirene" target="_blank">Facebook</a>
        <a href="https://youtube.com/@LoriRene2520" target="_blank">YouTube</a>
      </div>
    </footer>
  </body>
</html>

<style>
  :root {
    --pink: #e8357a;
    --teal: #3dbfb8;
    --dark: #1a1a1a;
    --light: #fafafa;
    --font-display: 'Playfair Display', serif;
    --font-body: 'Inter', sans-serif;
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html, body {
    width: 100%;
    min-height: 100%;
    font-family: var(--font-body);
    background: var(--light);
    color: var(--dark);
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 2rem;
    background: white;
    border-bottom: 2px solid var(--pink);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  nav .logo {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--pink);
    text-decoration: none;
  }

  nav ul {
    list-style: none;
    display: flex;
    gap: 2rem;
  }

  nav ul a {
    text-decoration: none;
    color: var(--dark);
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    transition: color 0.2s;
  }

  nav ul a:hover {
    color: var(--pink);
  }

  footer {
    background: var(--dark);
    color: white;
    text-align: center;
    padding: 2rem;
    margin-top: 4rem;
    font-size: 0.875rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  footer a {
    color: var(--teal);
    text-decoration: none;
  }

  footer .socials {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
  }
</style>